{
  "name": "anvil",
  "version": "0.1.0",
  "description": "Agentic research CLI — typed multi-agent pipelines with replay, eval, and grounded citations",
  "type": "module",
  "bin": {
    "anvil": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "chat": "tsx src/cli.ts chat",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "agents",
    "research",
    "gemini"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.34.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "ora": "^8.2.0",
    "p-limit": "^6.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
